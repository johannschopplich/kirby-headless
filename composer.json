{
  "name": "johannschopplich/kirby-headless",
  "description": "API-first toolkit for Kirby CMS",
  "type": "kirby-plugin",
  "version": "7.0.0",
  "keywords": [
    "kirby",
    "headless"
  ],
  "license": "MIT",
  "homepage": "https://kirby.tools/docs/headless",
  "authors": [
    {
      "name": "Johann Schopplich",
      "email": "hello@johannschopplich.com",
      "homepage": "https://johannschopplich.com"
    }
  ],
  "require": {
    "php": ">=8.3",
    "getkirby/composer-installer": "^1"
  },
  "require-dev": {
    "getkirby/cms": "^5",
    "phpunit/phpunit": "^12"
  },
  "scripts": {
    "csfix": "@php tools/phpcs/vendor/bin/php-cs-fixer fix",
    "test": "phpunit",
    "dist": "composer install --no-dev --optimize-autoloader"
  },
  "config": {
    "optimize-autoloader": true,
    "allow-plugins": {
      "getkirby/composer-installer": true
    }
  },
  "extra": {
    "kirby-cms-path": false
  }
}
